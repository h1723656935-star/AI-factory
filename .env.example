# ============================================================
# 爆款工厂AI - 环境变量模板
# 复制本文件为 .env.local 并填入真实值
# ============================================================

# ------------------------------------------------------------
# 应用基础配置 (Required)
# ------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# ------------------------------------------------------------
# Supabase 配置 (Required for persistence & auth)
# 项目地址: https://supabase.com
# 需要创建项目后，从 Settings > API 中获取以下密钥
# ------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ------------------------------------------------------------
# Supabase Auth - OAuth 第三方登录 (Optional)
# 在 Supabase Dashboard > Authentication > Providers 中配置
# 无需在此处填写客户端 ID，前端直接调用 supabase.auth.signInWithOAuth
# ------------------------------------------------------------
# (no env vars required for OAuth)

# ------------------------------------------------------------
# AI 大模型 API 配置 (Required for AI features)
# 至少配置一个，推荐优先使用 OpenAI 或兼容 OpenAI 接口的服务
# ------------------------------------------------------------

# OpenAI / 兼容 OpenAI 接口的供应商 (推荐)
# 示例: sk-xxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude (可选)
# 示例: sk-ant-xxxxxxxx
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# 智谱 AI / Zhipu (可选，国内场景)
# 示例: xxxxxxxxxxxxxxxx.xxxxxxxx
ZHIPU_API_KEY=
ZHIPU_MODEL=glm-4-flash

# 百度文心一言 (可选)
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# 通义千问 / 阿里云百炼 (可选)
# 示例: sk-xxxxxxxx
DASHSCOPE_API_KEY=
DASHSCOPE_MODEL=qwen-turbo

# DeepSeek (可选)
# 示例: sk-xxxxxxxx
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ------------------------------------------------------------
# 视频平台解析与元数据抓取 (Optional)
# 用于爆款视频分析模块的视频信息提取
# ------------------------------------------------------------

# YouTube Data API v3 Key (用于解析 YouTube 视频)
YOUTUBE_API_KEY=

# 抖音 / 快手 / 小红书等平台解析服务
# 如果没有官方 API，可使用第三方解析服务（如 yt-dlp、RapidAPI 等）
VIDEO_PARSER_API_URL=
VIDEO_PARSER_API_KEY=

# yt-dlp 二进制路径（如已本地安装）
YT_DLP_PATH=yt-dlp

# ------------------------------------------------------------
# AI 图像生成配置 (Optional)
# 用于分镜预览图生成和提示词优化
# ------------------------------------------------------------

# Midjourney / Imagine API 代理（第三方 API）
MIDJOURNEY_API_URL=
MIDJOURNEY_API_KEY=

# Stable Diffusion WebUI / ComfyUI / API
STABLE_DIFFUSION_API_URL=http://localhost:7860

# DALL·E 3 (使用 OpenAI 密钥即可，无需单独配置)

# ------------------------------------------------------------
# 支付与订阅配置 (Optional)
# 用于会员订阅系统
# ------------------------------------------------------------

# Stripe (国际支付 / 信用卡)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PREMIUM=
STRIPE_PRICE_ENTERPRISE=

# 支付宝 (国内支付)
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do

# 微信支付 (国内支付)
WECHAT_PAY_MCH_ID=
WECHAT_PAY_APP_ID=
WECHAT_PAY_API_V3_KEY=
WECHAT_PAY_CERT_SERIAL_NO=
WECHAT_PAY_PRIVATE_KEY_PATH=

# ------------------------------------------------------------
# 安全与限流配置 (Optional)
# ------------------------------------------------------------

# 用于 NextAuth / 密码重置邮件 / JWT 签名
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# 通用 API 请求密钥（用于服务端与服务端通信）
API_SECRET_KEY=

# IP 请求速率限制：每分钟最大请求数
RATE_LIMIT_MAX_REQUESTS=60

# ------------------------------------------------------------
# 第三方服务与监控 (Optional)
# ------------------------------------------------------------

# Vercel 部署令牌（CI/CD 使用，一般配置在 GitHub Secrets 中）
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=

# Sentry / LogRocket 等错误监控
SENTRY_DSN=

# 邮件服务（用于密码重置、通知）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@baokuan.ai
